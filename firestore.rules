rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin(schoolCode) {
      return isAuth() &&
        userData().role == 'admin' &&
        userData().schoolCode == schoolCode;
    }

    function isSchoolMember(schoolCode) {
      return isAuth() && userData().schoolCode == schoolCode;
    }

    function onlyDrillCheckInFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['checkedInUIDs', 'checkedInCount', 'checkIns', 'anonymousCount', 'lastScanAt', 'firstScanAt']);
    }

    match /disasters/{id} { allow read: if true; }
    match /quizzes/{id} { allow read: if true; }
    match /resources/{id} { allow read: if true; }

    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
    }

    match /schools/{schoolCode} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAdmin(schoolCode);
    }

    match /alerts/{alertId} {
      allow read: if isSchoolMember(resource.data.schoolCode);
      allow create: if isAdmin(request.resource.data.schoolCode);
      allow delete: if isAdmin(resource.data.schoolCode)
        || (isAuth() && resource.data.sentBy == request.auth.uid);
    }

    match /drills/{drillId} {
      allow read: if isSchoolMember(resource.data.schoolCode);
      allow create: if isAdmin(request.resource.data.schoolCode);
      allow update: if isAdmin(resource.data.schoolCode)
        || (isSchoolMember(resource.data.schoolCode) && onlyDrillCheckInFields());
      allow delete: if isAdmin(resource.data.schoolCode);
    }

    match /messages/{schoolCode}/channel/{messageId} {
      allow read: if isSchoolMember(schoolCode);
      allow create: if isSchoolMember(schoolCode);
    }
  }
}
