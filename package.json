{
  "name": "app-da",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "seed": "node scripts/seed.js",
    "db:seed": "node scripts/seed.js",
    "db:verify": "node scripts/verify-database.js",
    "db:deploy": "npx firebase deploy --only firestore",
    "functions:install": "npm install --prefix functions",
    "functions:deploy": "npm run functions:install && npx firebase deploy --only functions",
    "backend:deploy": "npm run functions:install && npx firebase deploy --only firestore,functions",
    "db:login": "npx firebase login",
    "db:setup": "node scripts/setup-database.js",
    "emulators": "npx firebase emulators:start --only auth,firestore,functions",
    "postinstall": "node scripts/patch-nearby-connections.js",
    "typecheck": "tsc --noEmit",
    "firebase:rules": "npx firebase deploy --only firestore",
    "eas:init": "npx eas-cli init",
    "eas:build:android": "npx eas-cli build --platform android --profile preview",
    "eas:build:ios": "npx eas-cli build --platform ios --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "^55.0.0",
    "expo-camera": "~55.0.19",
    "expo-constants": "~55.0.16",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-linking": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-nearby-connections": "^1.1.0",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-speech": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.16",
    "firebase": "^12.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-maps": "1.27.2",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "dotenv": "^16.6.1",
    "firebase-admin": "^13.0.2",
    "firebase-tools": "^14.12.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
